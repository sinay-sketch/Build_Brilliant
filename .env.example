# Firebase Web app config. Copy this file to `.env` and fill in the values
# from Firebase Console -> Project settings -> Your apps -> SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- Phase 2 AI (client flags) ----
# Master switch. Set to "false" to ship/run the pure Phase 1 app with no AI.
VITE_AI_ENABLED=true
# Per-feature switches (default on when AI is enabled).
VITE_AI_HINTS=true     # conversational tutor (hint + follow-up chat)
VITE_AI_GENERATE=true  # practice problem generator
VITE_AI_COACH=true     # personalized coach message on Home
# Set to "true" to call the local Functions emulator during development.
VITE_USE_FUNCTIONS_EMULATOR=false

# NOTE: the OpenAI key is NOT a client variable. It lives server-side in the
# Cloud Functions secret OPENAI_API_KEY:
#   npx firebase-tools@latest functions:secrets:set OPENAI_API_KEY
